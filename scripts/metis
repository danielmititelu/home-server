#!/bin/sh
COMPOSE_DIR="/home-server"

usage() {
  echo "Usage: metis <up|down|restart|logs> <container name>"
  echo "       metis status"
  echo "       metis sync"
  echo "       metis backup"
  echo "       metis vaultling"
  echo "       metis init"
  exit 1
}

status() {
  cpu=$(top -bn1 | awk '/^%Cpu/{print $2}')
  mem=$(free | awk '/Mem:/{printf "%.1f", $3/$2*100}')
  temp=$(awk '{printf "%.1f", $1/1000}' /sys/class/thermal/thermal_zone0/temp 2>/dev/null || echo "N/A")
  echo "CPU Usage:   ${cpu}%"
  echo "Memory:      ${mem}%"
  echo "Temperature: ${temp} °C"
}

vaultling() {
  cd /home-server/vaultling/Vaultling/bin/Release/net10.0/publish
  /home/pi/.dotnet/dotnet Vaultling.dll
}

[ $# -lt 1 ] && usage

COMMAND="$1"
SERVICE="$2"

case "$COMMAND" in
  up|down|restart|logs)
    [ -z "$SERVICE" ] && usage
    ;;
esac

case "$COMMAND" in
  up)      docker compose up -d "$SERVICE" ;;
  down)    docker compose down "$SERVICE" ;;
  restart) docker compose restart "$SERVICE" ;;
  logs)    docker compose logs -f "$SERVICE" ;;
  status)  status ;;
  sync)    /home-server/scripts/sync.sh ;;
  backup)    /home-server/scripts/backup.sh ;;
  vaultling) vaultling ;;
  init)      /home-server/scripts/init.sh ;;
  *)         usage ;;
esac
