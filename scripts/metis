#!/bin/sh
COMPOSE_DIR="/home-server"
SYSTEMD_SERVICES="kodi homebot"

usage() {
  echo "Usage: metis <start|stop|restart|logs> <container|service>"
  echo "       metis status"
  echo "       metis sync"
  echo "       metis backup"
  echo "       metis vaultling"
  echo "       metis init"
  exit 1
}

is_systemd() { echo "$SYSTEMD_SERVICES" | grep -qw "$1"; }

status() {
  cpu=$(top -bn1 | awk '/^%Cpu/{print $2}')
  mem=$(free | awk '/Mem:/{printf "%.1f", $3/$2*100}')
  temp=$(awk '{printf "%.1f", $1/1000}' /sys/class/thermal/thermal_zone0/temp 2>/dev/null || echo "N/A")
  echo "CPU Usage:   ${cpu}%"
  echo "Memory:      ${mem}%"
  echo "Temperature: ${temp} °C"
}

vaultling() {
  cd /home-server/vaultling/Vaultling/bin/Release/net10.0/publish
  /home/pi/.dotnet/dotnet Vaultling.dll
}

start() {
  if is_systemd "$SERVICE"; then systemctl start "$SERVICE"
  else docker compose -f "$COMPOSE_DIR/docker-compose.yaml" up -d "$SERVICE"; fi
}

stop() {
  if is_systemd "$SERVICE"; then systemctl stop "$SERVICE"
  else docker compose -f "$COMPOSE_DIR/docker-compose.yaml" stop "$SERVICE"; fi
}

restart() {
  if is_systemd "$SERVICE"; then systemctl restart "$SERVICE"
  else docker compose -f "$COMPOSE_DIR/docker-compose.yaml" restart "$SERVICE"; fi
}

logs() {
  if is_systemd "$SERVICE"; then journalctl -u "$SERVICE" -f
  else docker compose -f "$COMPOSE_DIR/docker-compose.yaml" logs -f "$SERVICE"; fi
}

[ $# -lt 1 ] && usage

COMMAND="$1"
SERVICE="$2"

case "$COMMAND" in
  start|stop|restart|logs)
    [ -z "$SERVICE" ] && usage
    ;;
esac

case "$COMMAND" in
  start)     start ;;
  stop)      stop ;;
  restart)   restart ;;
  logs)      logs ;;
  status)    status ;;
  sync)      /home-server/scripts/sync.sh ;;
  backup)    /home-server/scripts/backup.sh ;;
  vaultling) vaultling ;;
  init)      /home-server/scripts/init.sh ;;
  *)         usage ;;
esac
